{
    "name": "discord-manager",
    "version": "2.0.0",
    "description": "A powerful and customizable Discord bot to enhance your performance experience. Useful for supporting productivity in working on airdrops.",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "discord:typing": "node src/newAutoTyping.js",
        "discord:chat": "node src/newAutoChat.js",
        "discord:moderation": "node src/newAutoModeration.js",
        "discord:schedule": "node src/newAutoSchedule.js",
        "discord:reaction": "node src/newAutoReaction.js",
        "discord:faucet": "node src/newAutoFaucet.js",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "cross-env NODE_ENV=test mocha --recursive test/**/*.test.js",
        "test:unit": "cross-env NODE_ENV=test mocha --recursive test/unit/**/*.test.js",
        "test:integration": "cross-env NODE_ENV=test mocha --recursive test/integration/**/*.test.js",
        "test:e2e": "cross-env NODE_ENV=test mocha --recursive test/e2e/**/*.test.js",
        "test:coverage": "cross-env NODE_ENV=test c8 --reporter=lcov --reporter=text npm test",
        "test:watch": "cross-env NODE_ENV=test mocha --recursive test/**/*.test.js --watch",
        "verify": "npm run lint && npm run format:check && npm test",
        "clean": "node -e \"require('fs').rmSync('logs', {recursive:true, force:true}); require('fs').rmSync('coverage', {recursive:true, force:true})\"",
        "prepublishOnly": "npm run verify"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/thenatarizkie/discord-manager.git"
    },
    "keywords": [
        "natarizkie",
        "discord-bot",
        "discord-manager",
        "auto-chat",
        "forbidden-words",
        "auto-gm-gn",
        "discord-self-tools",
        "auto-reaction",
        "discord-automation",
        "auto-typing"
    ],
    "author": "Natarizkie",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/thenatarizkie/discord-manager/issues"
    },
    "homepage": "https://github.com/thenatarizkie/discord-manager#readme",
    "devDependencies": {
        "@eslint/js": "^9.17.0",
        "@jsdevtools/npm-publish": "^3.1.1",
        "c8": "^11.0.0",
        "chai": "^5.1.2",
        "cross-env": "^10.1.0",
        "eslint": "^9.17.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.1",
        "execa": "^9.5.2",
        "globals": "^16.0.0",
        "ignore": "^7.0.0",
        "mocha": "^11.0.1",
        "prettier": "^3.4.2",
        "sinon": "^19.0.2",
        "typescript": "^5.9.3",
        "yargs": "^17.7.2"
    },
    "dependencies": {
        "@discord/embedded-app-sdk": "^1.4.2",
        "@discordjs/voice": "^0.18.0",
        "@google/genai": "^1.45.0",
        "axios": "^1.6.8",
        "bad-words-next": "^3.1.1",
        "body-parser": "^2.2.2",
        "bufferutil": "^4.0.8",
        "chalk": "^5.3.0",
        "cheerio": "^1.0.0-rc.3",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "delay": "^6.0.0",
        "discord-simple-api": "^1.0.6",
        "discord.js": "^14.15.3",
        "discord.js-selfbot-v13": "^3.4.5",
        "dotenv": "^16.4.5",
        "dotenv-flow": "^4.1.0",
        "express": "^4.19.1",
        "franc": "^6.2.0",
        "helmet": "^8.0.0",
        "i18next": "^24.0.5",
        "inspirational-quotes": "^2.0.1",
        "jsdom": "^26.0.0",
        "langs": "^2.0.0",
        "languagedetect": "^2.0.0",
        "node-fetch": "^3.3.2",
        "node-schedule": "^2.1.1",
        "nodemon": "^3.1.0",
        "ora": "^8.0.1",
        "playwright-chromium": "^1.42.1",
        "prompts": "^2.4.2",
        "puppeteer": "^24.0.0",
        "random-words": "^2.0.1",
        "readline-sync": "^1.4.10",
        "string-similarity": "^4.0.4",
        "translate-google": "^1.5.0",
        "utf-8-validate": "^6.0.6",
        "vercel": "^50.32.5"
    }
}
